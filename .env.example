# Database Configuration
DB_HOST=${MYSQL_HOSTNAME}
DB_USER=${MYSQL_USER}
DB_PASSWORD=${MYSQL_PASSWORD}
DB_NAME=${MYSQL_DB}
DB_PORT=${MYSQL_PORT}

# App Configuration
APP_ENV=production
APP_DEBUG=false
APP_URL=https://yourdomain.railway.app

# Timezone
TIMEZONE=Asia/Jakarta

# Session Configuration
SESSION_DRIVER=file
SESSION_LIFETIME=120
