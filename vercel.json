{
  "version": 2,
  "public": false,
  "buildCommand": "echo 'Perpus Pelita - PHP Library Management System'",
  "outputDirectory": ".",
  "env": {
    "DB_HOST": "@db_host",
    "DB_USER": "@db_user",
    "DB_PASSWORD": "@db_password",
    "DB_NAME": "@db_name"
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "index.php"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ]
}
